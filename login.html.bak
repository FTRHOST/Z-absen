<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Zie Absen</title>
    <!-- Bootstrap CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
      :root {
        --bs-primary: #e5b82a;
        --bs-body-bg: #fdfbf7;
        --bs-body-color: #3e2723;
      }
      body {
        background-color: var(--bs-body-bg) !important;
        color: var(--bs-body-color) !important;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .btn-primary {
        background-color: #e5b82a !important;
        border-color: #e5b82a !important;
        color: #3e2723 !important;
      }
      .btn-primary:hover {
        background-color: #d4af37 !important;
        border-color: #d4af37 !important;
      }
      .login-card {
        border: none;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        overflow: hidden;
      }
      .<-header {
        background: linear-gradient(135deg, #e5b82a, #d4af37) !important;
        color: #3e2723 !important;
        padding: 30px 20px;
        text-align: center;
      }
      .login-header h3 {
        margin: 0;
        font-weight: 700;
      }
      .login-body {
        padding: 40px 30px;
        background-color: #ffffff;
      }
      .form-control {
        padding: 12px 15px;
        border-radius: 8px;
      }
      .btn-login {
        padding: 12px;
        font-weight: bold;
        border-radius: 8px;
        letter-spacing: 1px;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">
          <div class="card login-card">
            <div class="login-header">
              <h3>ZIEDA ABSEN</h3>
              <p class="mb-0 mt-2 opacity-75">Silakan masuk ke akun Anda</p>
            </div>
            <div class="login-body">
              <form id="loginForm" onsubmit="prosesLogin(event)">
                <div class="mb-3">
                  <label
                    for="inputNama"
                    class="form-label fw-bold small text-muted"
                    >Nama Pengguna</label
                  >
                  <input
                    type="text"
                    class="form-control"
                    id="inputNama"
                    placeholder="Masukkan nama Anda"
                    required
                  />
                </div>
                <div class="mb-4">
                  <label
                    for="inputPassword"
                    class="form-label fw-bold small text-muted"
                    >Password</label
                  >
                  <input
                    type="password"
                    class="form-control"
                    id="inputPassword"
                    placeholder="Masukkan password"
                    required
                  />
                </div>

                <div class="d-grid mb-3">
                  <button type="submit" class="btn btn-primary btn-login">
                    LOGIN
                  </button>
                </div>

                <div class="text-center mt-3">
                  <a href="#" class="text-decoration-none small"
                    >Lupa password? Hubungi HR</a
                  >
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Pustaka Supabase -->
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <!-- Konfigurasi Global -->
    <script src="config.js"></script>

    <script>
      document.addEventListener("DOMContentLoaded", async () => {
        try {
          const { data } = await supabaseClient
            .from("app_settings")
            .select("nama_aplikasi")
            .eq("id", 1)
            .single();
          if (data && data.nama_aplikasi) {
            document.title = `Login - ${data.nama_aplikasi}`;
            document.querySelector("h3").innerHTML = `${data.nama_aplikasi}`;
          }
        } catch (e) {
          console.error(e);
        }
      });

      // ==========================================
      // ==========================================
      // FUNGSI LOGIN
      // ==========================================
      async function prosesLogin(event) {
        event.preventDefault();
        const namaUser = document.getElementById("inputNama").value.trim();
        const password = document.getElementById("inputPassword").value;
        const btnLogin = document.querySelector(".btn-login");

        btnLogin.disabled = true;
        btnLogin.innerHTML = "Memeriksa...";

        try {
          // Buat email palsu dari nama user (contoh: budi santoso -> budisantoso@zieabsen.internal)
          const dummyEmail = `${namaUser.replace(/\s+/g, '').toLowerCase()}@zieabsen.internal`;
          
          let authResult = await supabaseClient.auth.signInWithPassword({
            email: dummyEmail,
            password: password
          });

          let userData = null;

          // JIKA BELUM ADA DI SUPABASE AUTH (Pendaftaran Otomatis Saat Pertama Kali Login)
          if (authResult.error && authResult.error.message.includes("Invalid login credentials")) {
            
            // 1. Kita DAFTARKAN otomatis ke Supabase Auth
            const signUpResult = await supabaseClient.auth.signUp({
              email: dummyEmail,
              password: password
            });

            if (signUpResult.error && !signUpResult.error.message.includes("already registered")) {
              throw new Error("Gagal mendaftarkan sistem keamanan: " + signUpResult.error.message);
            }

// Dapatkan user ID Auth yang baru
let authUserId = signUpResult.data?.user?.id;

// Jika authUserId kosong (karena email "already registered" saat signUp), coba login lagi
if (!authUserId) {
    const retryLogin = await supabaseClient.auth.signInWithPassword({ email: dummyEmail, password });
    
    // Jika retryLogin gagal atau usernya null, berarti password yang dimasukkan SALAH
    if (retryLogin.error || !retryLogin.data.user) {
        throw new Error("Password yang Anda masukkan salah!");
    }
    
    authUserId = retryLogin.data.user.id;
}

            // 2. Hubungkan ke database secara aman via Server-Side RPC
            // Ini akan memvalidasi password asli dan menghubungkan auth_id ke tabel profil
            const { data: linkedData, error: linkError } = await supabaseClient
              .rpc("link_my_account", { p_nama: namaUser, p_password: password });
              
            if (linkError || !linkedData) {
              throw new Error("Nama atau Password di database pusat salah!");
            }
            
            userData = linkedData;
            userData.auth_id = authUserId; // Update local obj

          } else if (authResult.error) {
             throw new Error(authResult.error.message);
          } else {
             // JIKA SUDAH PERNAH LOGIN (SUDAH TERDAFTAR DI AUTH)
             const { data: profile } = await supabaseClient.from("users").select("*").eq("auth_id", authResult.data.user.id).single();
             if (!profile) {
                throw new Error("Data profil tidak ditemukan.");
             }
             userData = profile;
          }

          // Simpan sesi login ke LocalStorage (sebagai transisi sebelum full JWT)
          localStorage.setItem("userLogin", JSON.stringify(userData));

          Swal.fire({
            title: "Berhasil Login!",
            text: `Selamat datang kembali, ${userData.nama}!`,
            icon: "success",
            timer: 1500,
            showConfirmButton: false,
          }).then(() => {
            // Super Admin tidak absen, langsung ke Admin Panel
            if (userData.role === "Super Admin") {
              window.location.href = "admin.html";
            } else {
              // HR dan Karyawan ke halaman absen
              window.location.href = "index.html";
            }
          });
        } catch (err) {
          Swal.fire("Login Gagal", err.message, "error");
          btnLogin.disabled = false;
          btnLogin.innerHTML = "LOGIN";
        }
      }
    </script>
  </body>
</html>
